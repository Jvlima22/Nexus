# ──────────────────────────────────────────────────────────────────────────────
# NEXUS Trader — Variáveis de ambiente
# Copie para `.env` e preencha. Nunca comitar `.env`.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (frontend — público, injetado no bundle via VITE_)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# Supabase (server-side apenas — NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Cifra de credenciais de corretora (AES-256-GCM)
# Gere com: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
BROKER_ENCRYPTION_KEY=base64-32-bytes

# Deriv OAuth (https://api.deriv.com → Register App)
# DERIV_APP_ID precisa ser igual no servidor (validação WS) e no client (montar a URL)
DERIV_APP_ID=seu-app-id
VITE_DERIV_APP_ID=seu-app-id
DERIV_OAUTH_REDIRECT_URL=http://localhost:5173/api/connections/deriv/callback

# NEXUS Connector (ponte com a IQ Option). WS é derivado da HTTP se omitido.
VITE_CONNECTOR_URL=http://localhost:8000
# VITE_CONNECTOR_WS_URL=ws://localhost:8000

# Inteligência — Knowledge/RAG (prompt caching). Secret do WORKER → vai no .dev.vars
# (dev) ou `wrangler secret put ANTHROPIC_API_KEY` (prod). NÃO usar prefixo VITE_.
# ANTHROPIC_API_KEY=sk-ant-api03-...
# NEXUS_CLAUDE_MODEL=claude-sonnet-4-6
