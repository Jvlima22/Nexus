# ── NEXUS Connector — variáveis de ambiente ──────────────────────────────────
# Copie para .env (local) ou configure no painel do Render (prod).

# Autenticação na IQ Option. CAMINHO RECOMENDADO: email + senha (a lib loga e
# gerencia o SSID internamente — mais confiável que injetar SSID).
IQ_EMAIL=
IQ_PASSWORD=

# Fallback por SSID (best-effort; o fork não injeta SSID de forma estável):
#  (a) DEV: cole o SSID aqui.  (b) PROD: use SSID_ENDPOINT + SSID_TOKEN (Worker).
IQ_SSID=
SSID_ENDPOINT=
SSID_TOKEN=

# Conta da IQ a usar: PRACTICE (demo) ou REAL.
IQ_BALANCE_MODE=PRACTICE

# Supabase (Fases 3-5) — service_role bypassa RLS para escrever assets/trades/saldo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# user_id (auth.users) dono dos dados que o Connector grava.
NEXUS_USER_ID=

# ── Polymarket (Fase 4) — sentimento macro = filtro primário de direção ──
# CSV de slugs de mercados da Gamma a monitorar (vazio = camada desligada).
# Ex: fed-decreases-interest-rates-in-2026,us-recession-in-2026
POLYMARKET_SLUGS=
POLYMARKET_POLL_S=120
POLYMARKET_BULL_THRESHOLD=0.65
POLYMARKET_BEAR_THRESHOLD=0.35
# Veta ordens que contrariam o bias macro (regra 0 do Risk Judge)?
POLYMARKET_GATE_ENABLED=true

# ── Sessões de mercado (Fase 5) — só opera nas janelas de maior liquidez ──
# Veta ordens fora de Londres/NY (horários em UTC). false = opera 24h.
SESSION_GATE_ENABLED=true
SESSION_LONDON_START=8
SESSION_LONDON_END=17
SESSION_NY_START=13
SESSION_NY_END=22

# ── Calendário ForexFactory (Fase 6) — blackout em notícias de alto impacto ──
CALENDAR_GATE_ENABLED=true
CALENDAR_POLL_S=1800
CALENDAR_BLACKOUT_BEFORE_MIN=15
CALENDAR_BLACKOUT_AFTER_MIN=15
# Níveis que disparam blackout (CSV): High | High,Medium
CALENDAR_IMPACTS=High

# ── Risk Judge (Fase 3) — overrides opcionais (defaults no config.py) ──
# RISK_PCT=0.02
# MIN_CONFIDENCE=0.70
# MAX_CONSECUTIVE_LOSSES=3
# DAILY_LOSS_CAP_PCT=0.06

# ── Autotrader (Fase 7) — robô determinístico (substitui o laço OpenClaw+IA) ──
# DESLIGADO por padrão (kill switch). Liga aqui ou via POST /autotrader/toggle.
# Opera no modo da conta (IQ_BALANCE_MODE); deixe em PRACTICE até validar.
AUTOTRADER_ENABLED=false
# Descoberta dinâmica: varre os ativos ABERTOS (lidos do Supabase) em vez da lista fixa.
AUTOTRADER_SCAN_OPEN=true
# Universo: currencies (só pares de moeda ISO) | all (moeda+cripto+ação+índice).
AUTOTRADER_UNIVERSE=currencies
# Exclui pares OTC da watchlist (provados random walk em 07/06). true = só forex REAL
# em pregão; em fim de semana (só OTC aberto) a watchlist fica vazia e o robô não opera.
AUTOTRADER_EXCLUDE_OTC=true
# Ignora ativos com payout abaixo disso (%) e limita quantos avaliar por ciclo.
AUTOTRADER_MIN_PAYOUT=70
AUTOTRADER_MAX_ASSETS=30
# TTL do cache da watchlist (s).
AUTOTRADER_ASSETS_REFRESH_S=300
# Trava de risco: máx. posições abertas ao mesmo tempo (cada ordem = 2% da banca).
AUTOTRADER_MAX_OPEN=3
# Watchlist fixa (fallback quando AUTOTRADER_SCAN_OPEN=false).
AUTOTRADER_ASSETS=EURUSD
# Timeframes em segundos: primário (sinal) e confirmação (confluência).
AUTOTRADER_TIMEFRAME=300
AUTOTRADER_CONFIRM_TF=900
# Só opera se os dois timeframes concordam na direção.
AUTOTRADER_REQUIRE_CONFLUENCE=true
# Gate de regime (prompt #4): pula chop lateral de baixa vol (seguidor de tendência).
AUTOTRADER_REGIME_GATE_ENABLED=true
# Intervalo do laço de decisão (s) e nº de candles por análise.
AUTOTRADER_POLL_S=60
AUTOTRADER_CANDLES=200
# Expiração das ordens (min) e tipo (binary | digital).
AUTOTRADER_EXPIRATION_MIN=5
AUTOTRADER_OPTION_TYPE=binary
# Espera no ativo após executar/vetar uma ordem (s) — evita metralhar o mesmo sinal.
AUTOTRADER_COOLDOWN_S=300

# Gate de evidência (Robô OTC v2): só opera par com acerto MEDIDO (backtest) acima
# do breakeven com margem. Pré-filtro do autotrader, não regra do Risk Judge.
AUTOTRADER_EDGE_GATE_ENABLED=true
# Acerto mínimo p/ habilitar o par (breakeven do payout 84% ≈ 54,3%; 0.57 = margem).
AUTOTRADER_EDGE_MIN_HIT=0.57
# Amostra mínima de sinais p/ confiar na taxa medida.
AUTOTRADER_EDGE_MIN_SAMPLE=250
# Medir o recorte COM confluência (o que o robô realmente opera) vs. M5 cru.
AUTOTRADER_EDGE_USE_CONFLUENCE=true
# Recalcula o edge a cada N s (backtest é pesado — 6h = 21600).
AUTOTRADER_EDGE_REFRESH_S=21600

# ── MetaTrader 5 ─────────────────────────────────────────────────────────────
# Login numérico da conta MT5 (ex: 12345678)
MT5_LOGIN=
# Senha da conta MT5
MT5_PASSWORD=
# Nome do servidor broker (ex: MetaQuotes-Demo, XMGlobal-Demo 3)
MT5_SERVER=

# Servidor HTTP/WS do Connector.
PORT=8000
# Origens permitidas (CORS). Vite dev roda em 5173.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
