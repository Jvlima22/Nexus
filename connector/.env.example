# ── NEXUS Connector — variáveis de ambiente ──────────────────────────────────
# Copie para .env (local) ou configure no painel do Render (prod).

# Autenticação na IQ Option. CAMINHO RECOMENDADO: email + senha (a lib loga e
# gerencia o SSID internamente — mais confiável que injetar SSID).
IQ_EMAIL=
IQ_PASSWORD=

# Fallback por SSID (best-effort; o fork não injeta SSID de forma estável):
#  (a) DEV: cole o SSID aqui.  (b) PROD: use SSID_ENDPOINT + SSID_TOKEN (Worker).
IQ_SSID=
SSID_ENDPOINT=
SSID_TOKEN=

# Conta da IQ a usar: PRACTICE (demo) ou REAL.
IQ_BALANCE_MODE=PRACTICE

# Supabase (Fases 3-5) — service_role bypassa RLS para escrever assets/trades/saldo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# user_id (auth.users) dono dos dados que o Connector grava.
NEXUS_USER_ID=

# Servidor HTTP/WS do Connector.
PORT=8000
# Origens permitidas a consumir REST/WS (CORS). O dev server do NEXUS roda em 8080.
ALLOWED_ORIGINS=http://localhost:8080
